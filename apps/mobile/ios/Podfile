platform :ios, '13.0'

# CocoaPods analytics sends network stats so disable it.
ENV['COCOAPODS_DISABLE_STATS'] = 'true'

project 'Runner', {
  'Debug' => :debug,
  'Profile' => :release,
  'Release' => :release,
}

def flutter_install_all_ios_pods(pods_path = nil)
  pod_helper_path = File.expand_path(File.join('..', 'Flutter', 'podhelper.rb'), __FILE__)
  unless File.exist?(pod_helper_path)
    puts "Warning: #{pod_helper_path} does not exist yet. It will be generated during flutter build."
    return
  end
  require pod_helper_path
  flutter_ios_podfile_setup
  flutter_install_all_ios_pods pods_path
end

target 'Runner' do
  use_frameworks!
  use_modular_headers!

  flutter_install_all_ios_pods File.dirname(File.realpath(__FILE__))
end

post_install do |installer|
  installer.pods_project.targets.each do |target|
    if respond_to?(:flutter_additional_ios_build_settings)
      flutter_additional_ios_build_settings(target)
    end
    
    target.build_configurations.each do |config|
      # Force Swift version to 5.0 if it is set to 6.0
      if config.build_settings['SWIFT_VERSION'] == '6.0'
        config.build_settings['SWIFT_VERSION'] = '5.0'
      end
      # Ensure consistent deployment target
      config.build_settings['IPHONEOS_DEPLOYMENT_TARGET'] = '13.0'
    end
  end
end
