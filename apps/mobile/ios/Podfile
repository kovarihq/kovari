# Uncomment this line to define a global platform for your project
# platform :ios, '12.0'

# CocoaPods analytics sends network stats so disable it.
ENV['COCOAPODS_DISABLE_STATS'] = 'true'

project 'Runner', {
  'Debug' => :debug,
  'Profile' => :profile,
  'Release' => :release,
}

def flutter_install_all_ios_pods(pods_path = nil)
  pod_helper_path = File.expand_path(File.join('..', 'Flutter', 'podhelper.rb'), __FILE__)
  unless File.exist?(pod_helper_path)
    puts "Warning: #{pod_helper_path} does not exist yet. It will be generated during flutter build."
    return
  end
  require pod_helper_path
  flutter_ios_podfile_setup
  flutter_install_all_ios_pods pods_path
end

target 'Runner' do
  use_frameworks!
  use_modular_headers!

  flutter_install_all_ios_pods File.dirname(File.realpath(__FILE__))
end

post_install do |installer|
  installer.pods_project.targets.each do |target|
    flutter_additional_ios_build_settings(target)
    
    # Ensure deployment target and other settings are consistent
    target.build_configurations.each do |config|
      config.build_settings['IPHONEOS_DEPLOYMENT_TARGET'] = '12.0'
    end
  end
end
