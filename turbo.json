{
  "$schema": "https://turbo.build/schema.json",
  "globalEnv": [
    "NODE_ENV",
    "NEXT_PUBLIC_SUPABASE_URL",
    "NEXT_PUBLIC_SUPABASE_ANON_KEY",
    "NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY",
    "NEXT_PUBLIC_CLERK_SIGN_IN_URL",
    "NEXT_PUBLIC_CLERK_SIGN_UP_URL",
    "NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL",
    "NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL"
  ],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": [".next/**", "!.next/cache/**"],
      "env": [
        "CLERK_SECRET_KEY",
        "NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY",
        "SUPABASE_URL",
        "SUPABASE_SERVICE_ROLE_KEY",
        "NEXT_PUBLIC_SUPABASE_URL",
        "NEXT_PUBLIC_SUPABASE_ANON_KEY",
        "REDIS_URL",
        "BREVO_API_KEY",
        "BREVO_FROM_EMAIL",
        "BREVO_FROM_NAME",
        "BREVO_REPLY_TO_EMAIL",
        "BREVO_REPLY_TO_NAME",
        "GEOAPIFY_API_KEY",
        "CLOUDINARY_CLOUD_NAME",
        "CLOUDINARY_API_KEY",
        "CLOUDINARY_API_SECRET",
        "NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME",
        "NEXT_PUBLIC_CLOUDINARY_UPLOAD_PRESET",
        "SENTRY_AUTH_TOKEN",
        "SENTRY_ORG",
        "SENTRY_PROJECT",
        "SENTRY_ENVIRONMENT",
        "ML_SERVER_URL",
        "UPLOADTHING_SECRET",
        "UPLOADTHING_APP_ID",
        "UPLOADTHING_TOKEN",
        "RESEND_API_KEY",
        "MAILTRAP_HOST",
        "MAILTRAP_PORT",
        "MAILTRAP_USER",
        "MAILTRAP_PASS",
        "EB_API_KEY",
        "FAST2SMS_API_KEY",
        "FAST2SMS_ROUTE",
        "TWO_FACTOR_API_KEY",
        "GEMINI_API_KEY",
        "GEMINI_MODEL",
        "CRON_SECRET",
        "LAUNCH_WAITLIST_MODE",
        "VAPID_PRIVATE_KEY",
        "VAPID_SUBJECT",
        "ADMIN_ALLOWLIST",
        "EMAIL_FROM",
        "SUPPORT_LINK",
        "GO_SERVICE_URL",
        "GO_MATCHING_SERVICE_URL",
        "UPSTASH_REDIS_REST_URL",
        "UPSTASH_REDIS_REST_TOKEN",
        "INTERNAL_API_SECRET_CURRENT",
        "NEXT_PUBLIC_ENABLE_V1_MATCHING",
        "GOOGLE_CLIENT_ID",
        "JWT_ACCESS_SECRET",
        "JWT_REFRESH_SECRET",
        "CLERK_WEBHOOK_SECRET",
        "BETA_MODE",
        "WEB_APP_URL",
        "FIREBASE_PROJECT_ID",
        "FIREBASE_CLIENT_EMAIL",
        "FIREBASE_PRIVATE_KEY",
        "INTERNAL_NOTIFY_SECRET"
      ]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "lint": {
      "dependsOn": ["^lint"]
    },
    "socket": {
      "cache": false,
      "persistent": true,
      "env": [
        "REDIS_URL",
        "SUPABASE_URL",
        "SUPABASE_SERVICE_ROLE_KEY",
        "VAPID_PUBLIC_KEY",
        "VAPID_PRIVATE_KEY",
        "VAPID_SUBJECT"
      ]
    },
    "check-types": {
      "dependsOn": ["^check-types"]
    }
  }
}
